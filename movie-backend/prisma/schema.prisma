// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// USER MODEL 
model User {
  id             String         @id @default(uuid())
  firstName      String
  lastName       String
  email          String         @unique 
  phone          String?
  country        String?
  password       String  
  profilePicture String?
  avatarUrl      String?        // ADDED: To match Frontend payload
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  playlists      Playlist[]
  history        WatchHistory[]
  watchLater     WatchLater[]
  watchParties   WatchParty[]
  reviews        Review[]
}

// PLAYLIST MODELS
model Playlist {
  id        String         @id @default(uuid())
  name      String
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PlaylistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model PlaylistItem {
  id         String   @id @default(uuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  tmdbId     String
  title      String
  posterPath String?
  mediaType  String   @default("movie") 
  addedAt    DateTime @default(now())
}

// WATCH HISTORY 
model WatchHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId     String
  title      String
  posterPath String?
  mediaType  String   @default("movie")
  season     Int?     
  episode    Int?     
  stoppedAt  Int?     @default(0) 
  watchedAt  DateTime @default(now())
}

// WATCH LATER 
model WatchLater {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId     String
  title      String
  posterPath String?
  mediaType  String   @default("movie")
  addedAt    DateTime @default(now())
  @@unique([userId, tmdbId]) 
}

// CACHED MOVIE MODEL 
model Movie {
  id           String   @id @default(uuid())
  tmdbId       String?  @unique
  title        String
  overview     String?  @db.Text
  posterPath   String?
  backdropPath String?
  videoUrl     String
  releaseDate  String?
  voteAverage  Float?   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WatchParty {
  id        String         @id @default(uuid())
  roomId    String         @unique
  roomName  String?        
  hostId    String
  host      User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  messages  PartyMessage[]
}

// movie-backend/prisma/schema.prisma

model PartyMessage {
  id        String     @id @default(uuid())
  partyId   String
  party     WatchParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId    String?    
  userName  String
  avatarUrl String?  
  message   String
  type      String     @default("chat")
  createdAt DateTime   @default(now())
}

model Review {
  id        String   @id @default(uuid())
  tmdbId    String  
  rating    Float    
  content   String   
  userId    String  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}