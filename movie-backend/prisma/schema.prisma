// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Existing Movie model
model Movie {
  id           String   @id @default(uuid())
  tmdbId       String?  @unique
  title        String
  overview     String?  @db.Text
  posterPath   String?
  backdropPath String?
  videoUrl     String
  releaseDate  String?
  voteAverage  Float?   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// New User model for Authentication
model User {
  id             String   @id @default(uuid())
  firstName      String
  lastName       String
  email          String   @unique 
  phone          String?
  country        String?
  password       String  
  profilePicture String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}