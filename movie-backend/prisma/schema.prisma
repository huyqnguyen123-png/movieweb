// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ENUMS FOR NEW FEATURES
enum Role {
  USER
  ADMIN
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// USER MODEL 
model User {
  id             String         @id @default(uuid())
  firstName      String
  lastName       String
  email          String         @unique 
  phone          String?
  country        String?
  password       String  
  profilePicture String?
  avatarUrl      String?      
  role           Role           @default(USER) 
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Existing Relations
  playlists      Playlist[]
  history        WatchHistory[]
  watchLater     WatchLater[]
  watchParties   WatchParty[]
  reviews        Review[]
  messages       PartyMessage[] 
  sentRequests   Friendship[]   @relation("Requester")
  receivedReqs   Friendship[]   @relation("Receiver")
  notifications  Notification[]
}

// PLAYLIST MODELS
model Playlist {
  id        String         @id @default(uuid())
  name      String
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PlaylistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model PlaylistItem {
  id         String   @id @default(uuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  tmdbId     String
  title      String
  posterPath String?
  mediaType  String   @default("movie") 
  addedAt    DateTime @default(now())
}

// WATCH HISTORY 
model WatchHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId     String
  title      String
  posterPath String?
  mediaType  String   @default("movie")
  season     Int?      
  episode    Int?      
  stoppedAt  Int?     @default(0) 
  duration   Int?     @default(0) 
  watchedAt  DateTime @default(now())
}

// WATCH LATER 
model WatchLater {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId     String
  title      String
  posterPath String?
  mediaType  String   @default("movie")
  addedAt    DateTime @default(now())
  @@unique([userId, tmdbId]) 
}

// CACHED MOVIE MODEL
model Movie {
  id           String   @id @default(uuid())
  tmdbId       String?  @unique
  title        String
  overview     String?  @db.Text
  posterPath   String?
  backdropPath String?
  videoUrl     String
  releaseDate  String?
  voteAverage  Float?   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// WATCH PARTY & MESSAGES
model WatchParty {
  id        String         @id @default(uuid())
  roomId    String         @unique
  roomName  String?        
  hostId    String
  host      User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  messages  PartyMessage[]
}

model PartyMessage {
  id        String     @id @default(uuid())
  partyId   String
  party     WatchParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId    String?    
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull) // ADDED: Relation to User model
  userName  String
  avatarUrl String?  
  message   String
  type      String     @default("chat")
  createdAt DateTime   @default(now())
}

// REVIEW MODEL
model Review {
  id        String   @id @default(uuid())
  tmdbId    String  
  rating    Float    
  content   String   
  userId    String  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// NEW MODELS FOR SOCIAL FEATURES
model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  receiverId  String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  requester   User             @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User             @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  senderId  String? 
  type      String   
  message   String
  link      String? 
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}